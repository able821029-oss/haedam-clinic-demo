# ============================================================
# 해담한의원 데모 — 환경 변수 예시
# 사용법: 이 파일을 .env 로 복사하고 실제 값 입력
#   cp .env.example .env
# .env 는 .gitignore 처리되어 깃 커밋되지 않음
# ============================================================

# ------------------------------------------------------------
# [1] 예약 폼 백엔드 연동
# ------------------------------------------------------------

# Option A: EmailJS (가장 간단, 백엔드 불필요)
# https://www.emailjs.com/  → Email Services → Templates
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_SERVICE_ID=service_xxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxx

# Option B: Naver Cloud SENS (카카오 알림톡 / SMS)
# https://www.ncloud.com/product/applicationService/sens
NCP_ACCESS_KEY=your_ncp_access_key
NCP_SECRET_KEY=your_ncp_secret_key
NCP_SERVICE_ID=ncp:sms:kr:xxxx
NCP_PHONE_NUMBER=01012345678

# Option C: Custom API (자체 백엔드)
BOOKING_API_URL=https://api.haedam.kr/booking
BOOKING_API_KEY=your_api_key

# ------------------------------------------------------------
# [2] 지도 / 길찾기
# ------------------------------------------------------------

# Naver Maps Open API (정확한 위치 기반 길찾기에 필요)
# https://www.ncloud.com/product/applicationService/maps
NAVER_MAPS_CLIENT_ID=your_naver_maps_client_id
NAVER_MAPS_CLIENT_SECRET=your_naver_maps_client_secret

# Naver Place ID (네이버 플레이스에 등록된 우리 한의원의 고유 ID)
# 등록 후 URL https://map.naver.com/p/entry/place/{placeId} 에서 확인
NAVER_PLACE_ID=1234567890

# Kakao Maps JavaScript Key (선택 — 카카오맵 임베드 시)
# https://developers.kakao.com/console/app
KAKAO_MAP_JS_KEY=your_kakao_js_key

# ------------------------------------------------------------
# [3] 마케팅 / 분석
# ------------------------------------------------------------

# Google Analytics 4
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager
GTM_CONTAINER_ID=GTM-XXXXXXX

# Naver Search Advisor (사이트 등록 인증용)
NAVER_VERIFICATION=your_naver_verification_code

# Naver Premium Log Analysis (프리미엄 로그 분석)
NAVER_LOG_KEY=your_naver_log_key

# Meta Pixel (페이스북/인스타그램 광고)
META_PIXEL_ID=000000000000000

# 카카오 픽셀
KAKAO_PIXEL_ID=000000000

# ------------------------------------------------------------
# [4] 채팅 / 상담 채널
# ------------------------------------------------------------

# 카카오톡 채널 ID
KAKAO_CHANNEL_ID=_YOURCHANNELID

# 채널톡 (선택)
CHANNEL_IO_PLUGIN_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ------------------------------------------------------------
# [5] reCAPTCHA (예약 폼 봇 차단)
# ------------------------------------------------------------

RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
